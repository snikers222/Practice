import java.util.ArrayList;
import java.util.List;

abstract class Animal {
    private String name;
    private int age;

    public Animal(String name, int age) {
        this.name = name;
        this.age = age;
    }

    public String getName() {
        return name;
    }

    public int getAge() {
        return age;
    }

    public abstract void makeSound();

    public void displayInfo() {
        System.out.print("Тварина: " + getClass().getSimpleName() + " | Ім'я: " + name + ", Вік: " + age + " р. -> ");
    }
}

class Dog extends Animal {
    public Dog(String name, int age) {
        super(name, age);
    }

    @Override
    public void makeSound() {
        System.out.println("Гав-гав!");
    }
}

class Cat extends Animal {
    public Cat(String name, int age) {
        super(name, age);
    }

    @Override
    public void makeSound() {
        System.out.println("Мяу!");
    }
}

class Bird extends Animal {
    public Bird(String name, int age) {
        super(name, age);
    }

    @Override
    public void makeSound() {
        System.out.println("Ців-ців!");
    }
}

public class exam20 {
    public static void main(String[] args) {
        List<Animal> animalRegistry = new ArrayList<>();

        animalRegistry.add(new Dog("Сірко", 3));
        animalRegistry.add(new Cat("Мурчик", 2));
        animalRegistry.add(new Bird("Кеша", 1));
        animalRegistry.add(new Dog("Рекс", 5));

        System.out.println("СИСТЕМА ОБЛІКУ ТВАРИН");

        for (Animal animal : animalRegistry) {
            animal.displayInfo();
            animal.makeSound();
        }
    }
}
